{
  "name": "tasknote",
  "version": "1.1.0",
  "description": "TaskNote - 일정 관리 앱",
  "author": "Skedit99",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "clean": "rimraf release",
    "electron:build": "npm run clean && npm run build && electron-builder --win",
    "electron:publish": "npm run clean && npm run build && electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.tasknote.app",
    "productName": "TaskNote",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "build/",
        "to": "build/",
        "filter": [
          "*.ico",
          "*.png"
        ]
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ko-KR",
        "en-US"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "Skedit99",
      "repo": "TaskNote"
    }
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "googleapis": "^171.4.0",
    "immer": "^11.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "vite": "^8.0.0"
  }
}
